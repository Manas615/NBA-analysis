# ── OpenAI Configuration ─────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# ── PostgreSQL ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://nba:nba_password@localhost:5432/nba_trades
DATABASE_URL_SYNC=postgresql://nba:nba_password@localhost:5432/nba_trades
POSTGRES_USER=nba
POSTGRES_PASSWORD=nba_password
POSTGRES_DB=nba_trades

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Gemini (legacy fallback) ─────────────────────────────────
LLM_PROVIDER=openai
LLM_API_KEY=your_key_here
LLM_MODEL=gemini-2.0-flash

# ── Application ──────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# ── ChromaDB (RAG) ──────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
